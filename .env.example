# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Embedding provider: "ollama" (default), "openai", "mistral", or "voyage"
EMBEDDING_PROVIDER=ollama

# Embedding dimensions — auto-set per provider if omitted:
#   ollama: 512, openai: 1024, mistral: 1024, voyage: 1024
# Override only if using a non-default model with different dimensions.
# EMBEDDING_DIM=512

# Ollama settings (default)
# Use localhost for native install, host.docker.internal for Docker
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=embeddinggemma

# OpenAI settings (if EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Mistral settings (if EMBEDDING_PROVIDER=mistral)
# MISTRAL_API_KEY=your-mistral-key
# MISTRAL_EMBED_MODEL=mistral-embed

# Voyage settings (if EMBEDDING_PROVIDER=voyage)
# VOYAGE_API_KEY=your-voyage-key
# VOYAGE_EMBED_MODEL=voyage-4-lite

# Search defaults
# Threshold depends on embedding provider — each clusters vectors differently:
#   Ollama (embeddinggemma): 0.7 — tight clustering, scores run 0.8-0.9
#   Mistral (mistral-embed): 0.6 — tight clustering, similar to Ollama
#   Voyage (voyage-4-lite): 0.45 — moderate spread
#   OpenAI (text-embedding-3-small): 0.35 — widest spread, scores run 0.5-0.6
DEFAULT_MATCH_THRESHOLD=0.7
DEFAULT_MATCH_COUNT=10

# Memory profile (Severance-style partitioning: "lumon", "personal", "projects", etc)
DEFAULT_PROFILE=default
