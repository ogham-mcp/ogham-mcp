    "/tools/store_memory": {
      "post": {
        "operationId": "store_memory",
        "summary": "Store a memory in the active profile with automatic embedding generation.",
        "description": "Store a memory in the active profile with automatic embedding generation.\n\nArgs:\n    content: The text content to remember.\n    source: Where this came from (e.g. \"claude-desktop\", \"cursor\", \"claude-code\").\n    tags: Categorization tags for filtering (e.g. [\"project:foo\", \"type:decision\"]).\n    metadata: Additional structured data to store alongside the memory.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "content": {
                    "type": "string"
                  },
                  "source": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  },
                  "tags": {
                    "anyOf": [
                      {
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  },
                  "metadata": {
                    "anyOf": [
                      {
                        "additionalProperties": true,
                        "type": "object"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  }
                },
                "required": [
                  "content"
                ],
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/tools/hybrid_search": {
      "post": {
        "operationId": "hybrid_search",
        "summary": "Search memories in the active profile by meaning and keywords (hybrid search).",
        "description": "Search memories in the active profile by meaning and keywords (hybrid search).\n\nCombines semantic similarity (embeddings) with keyword matching (full-text search)\nusing Reciprocal Rank Fusion. Finds both conceptually similar memories and exact\nkeyword matches.\n\nArgs:\n    query: Natural language search query. Also used for keyword matching.\n    limit: Maximum number of results to return.\n    tags: Filter results to memories with any of these tags.\n    source: Filter results to memories from this source.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "limit": {
                    "default": 10,
                    "type": "integer"
                  },
                  "tags": {
                    "anyOf": [
                      {
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  },
                  "source": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  }
                },
                "required": [
                  "query"
                ],
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/tools/list_recent": {
      "post": {
        "operationId": "list_recent",
        "summary": "List recent memories in the active profile.",
        "description": "List recent memories in the active profile.\n\nArgs:\n    limit: Maximum number of memories to return.\n    source: Filter to memories from this source.\n    tags: Filter to memories with any of these tags.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "limit": {
                    "default": 10,
                    "type": "integer"
                  },
                  "source": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  },
                  "tags": {
                    "anyOf": [
                      {
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/tools/delete_memory": {
      "post": {
        "operationId": "delete_memory",
        "summary": "Delete a memory by its ID.",
        "description": "Delete a memory by its ID.\n\nArgs:\n    memory_id: The UUID of the memory to delete.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "memory_id": {
                    "type": "string"
                  }
