{
  "openapi": "3.1.0",
  "info": {
    "title": "Ogham MCP",
    "description": "MCP server providing persistent shared memory across AI clients. This spec documents the tool interfaces \u2014 the actual transport is MCP over stdio, not HTTP.",
    "version": "0.1.0"
  },
  "paths": {
    "/tools/switch_profile": {
      "post": {
        "operationId": "switch_profile",
        "summary": "Switch to a different memory profile. Like Severance -- each profile is",
        "description": "Switch to a different memory profile. Like Severance -- each profile is\na separate memory partition. Memories from other profiles are invisible.\n\nArgs:\n    profile: The profile to switch to (e.g. \"work\", \"personal\", \"default\").",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "profile": {
                    "type": "string"
                  }
                },
                "required": [
                  "profile"
                ],
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/tools/current_profile": {
      "post": {
        "operationId": "current_profile",
        "summary": "Show which memory profile is currently active.",
        "description": "Show which memory profile is currently active.",
