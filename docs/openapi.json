              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/tools/list_profiles": {
      "post": {
        "operationId": "list_profiles",
        "summary": "List all memory profiles and how many memories each has.",
        "description": "List all memory profiles and how many memories each has.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {},
                "type": "object"
              }
