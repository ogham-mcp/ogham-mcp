    },
    "/tools/get_stats": {
      "post": {
        "operationId": "get_stats",
        "summary": "Get summary statistics for the active memory profile.",
        "description": "Get summary statistics for the active memory profile.\n\nReturns total count, source breakdown, and top tags.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
