    },
    "/tools/get_cache_stats": {
      "post": {
        "operationId": "get_cache_stats",
        "summary": "Get embedding cache statistics.",
        "description": "Get embedding cache statistics.\n\nReturns current size, max size, hit/miss counts, eviction count, and hit rate.\nUseful for monitoring cache effectiveness.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {},
                "type": "object"
              }
            }
